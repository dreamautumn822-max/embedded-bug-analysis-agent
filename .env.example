# RAG / Chroma retrieval. FastEmbed runs a real Chinese semantic model locally.
CHROMA_DIR=.chroma
DOCS_DIR=data/docs
RAG_TOP_K=3
RAG_SCORE_THRESHOLD=0.1
RAG_CHUNK_SIZE=300
RAG_CHUNK_OVERLAP=50
RAG_RETRIEVAL_MODE=hybrid
RAG_CANDIDATE_K=8
RAG_RRF_K=60
RAG_VECTOR_WEIGHT=1.0
RAG_BM25_WEIGHT=1.0
RAG_RERANK_PROVIDER=local
RAG_RERANK_MODEL=ms-marco-MultiBERT-L-12
RAG_RERANK_WEIGHT=0.65
RAG_RERANK_CACHE_DIR=.cache/rerank
RAG_RERANK_MAX_LENGTH=256
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# Only used by the local lexical-hash fallback, not by FastEmbed/OpenAI.
EMBEDDING_DIMENSIONS=512
EMBEDDING_CACHE_DIR=.cache/embeddings
EMBEDDING_MAX_LENGTH=512
EMBEDDING_THREADS=
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=

BUG_HISTORY_PATH=data/bugs/bug_history.json
CODEBASE_DIR=data/codebase
# Set this host path when Docker should index a checked-out firmware repository.
CODE_REPOSITORY_PATH=./data/codebase
RAG_GIT_HISTORY_ENABLED=false
RAG_GIT_MAX_COMMITS=20
RAG_GIT_DIFF_MAX_CHARS=12000

# Root-cause LLM. Disabled by default; the rule chain remains the fallback.
LLM_ENABLED=false
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=30
LLM_TEMPERATURE=0.2

# Results below this confidence are marked pending human review.
AGENT_REVIEW_CONFIDENCE_THRESHOLD=0.70

# Durable LangGraph thread state for interrupt/resume human review.
LANGGRAPH_CHECKPOINT_PATH=run/bug_analysis_checkpoints.sqlite

# Redis/RQ persistent background jobs.
REDIS_URL=redis://127.0.0.1:6379/0
JOB_QUEUE_NAME=bug-analysis
JOB_TIMEOUT_SECONDS=120
JOB_MAX_TIMEOUT_SECONDS=900
JOB_RESULT_TTL_SECONDS=86400
JOB_FAILURE_TTL_SECONDS=86400
JOB_IDEMPOTENCY_TTL_SECONDS=86400
JOB_MAX_RETRIES=1

# API authentication. Generate hashes with scripts/hash_api_key.py.
API_AUTH_ENABLED=false
BUG_AGENT_API_KEY_HASHES_JSON={}
# Only consumed by the Streamlit client when authentication is enabled.
BUG_AGENT_API_KEY=

# Production case ticket hashing. Keep this secret outside Git.
BUG_AGENT_CASE_HASH_SALT=

# OpenTelemetry. The observability Compose overlay enables these automatically.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=embedded-bug-agent-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
OTEL_EXPORTER_OTLP_INSECURE=true

# Grafana login used by docker-compose.observability.yml.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-now
# Docker host ports (container ports remain 8000 and 8501)
BUG_AGENT_API_PORT=8000
BUG_AGENT_UI_PORT=8501
