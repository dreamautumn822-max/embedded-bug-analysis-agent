# RAG / Chroma document retrieval. The default local provider needs no API key.
CHROMA_DIR=.chroma
DOCS_DIR=data/docs
RAG_TOP_K=3
RAG_SCORE_THRESHOLD=0.1
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=local-hashing-v1
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=

BUG_HISTORY_PATH=data/bugs/bug_history.json
CODEBASE_DIR=data/codebase

# Root-cause LLM. Disabled by default; the rule chain remains the fallback.
LLM_ENABLED=false
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=30
LLM_TEMPERATURE=0.2
