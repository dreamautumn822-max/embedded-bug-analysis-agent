@startuml
title 嵌入式网通设备 Bug 分析 Agent - 运行部署图

skinparam shadowing false
skinparam nodeStyle rectangle

actor "用户" as User
node "Docker Compose" as Compose {
  node "API 容器\n8000 端口" as API
  node "前端容器\n8501 端口" as UI
  database "Chroma 具名卷" as Chroma
  database "SQLite 检查点具名卷" as Checkpoint
  folder "模型缓存具名卷\n中文 BGE / 重排模型" as Cache
}
folder "演示知识数据\n文档 / 历史 Bug / C 代码" as Data
artifact "环境变量文件" as Env
cloud "OpenAI 兼容 LLM 服务" as LLM
cloud "可选 OpenAI 兼容向量服务" as RemoteEmbedding
node "可选 Prometheus 服务" as Prometheus
node "GitHub Actions" as CI

User --> UI : 提交故障现场和复核决定
UI --> API : 调用分析与复核接口
API --> Data : 加载三类知识源
API --> Chroma : 同步和检索统一索引
API --> Checkpoint : 保存和恢复人工复核任务
API --> Cache : 加载本地中文 BGE
API --> LLM : 启用真实模型时
API --> RemoteEmbedding : 选择远程向量服务时
Env --> API : 模型、检索与检查点配置
Env --> UI : API 地址与超时
Prometheus --> API : 抓取运行指标端点
CI --> API : 编译、数据校验和自动化测试
@enduml
